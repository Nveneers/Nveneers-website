{
  "headline": "\u0647\u0644 \u0623\u0646\u062a \u0645\u0633\u062a\u0639\u062f \u0644",
  "highlightedText": "\u0627\u0628\u062a\u0633\u0627\u0645\u0629 \u0623\u062d\u0644\u0627\u0645\u0643\u061f",
  "body": "\u062d\u062f\u062f \u0645\u0648\u0639\u062f \u0627\u0633\u062a\u0634\u0627\u0631\u0629 \u0645\u0639 \u0637\u0628\u064a\u0628 \u0623\u0633\u0646\u0627\u0646 \u062a\u062c\u0645\u064a\u0644\u064a \u0645\u0639\u062a\u0645\u062f \u0644\u0645\u0639\u0631\u0641\u0629 \u0645\u0627 \u0625\u0630\u0627 \u0643\u0627\u0646\u062a \u0642\u0634\u0648\u0631 \u0627\u0644\u0623\u0633\u0646\u0627\u0646 \u0645\u0646\u0627\u0633\u0628\u0629 \u0644\u0643.",
  "cta": { "label": "\u0627\u062d\u062c\u0632 \u0627\u0633\u062a\u0634\u0627\u0631\u0629", "href": "#contact" }
