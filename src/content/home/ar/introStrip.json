  "eyebrow": "\u0645\u0627 \u0647\u064a \u0642\u0634\u0648\u0631 \u0627\u0644\u0623\u0633\u0646\u0627\u0646\u061f",
  "headline": "\u062b\u0648\u0631\u0629 \u0641\u064a \u0637\u0628 \u0627\u0644\u0623\u0633\u0646\u0627\u0646 \u0627\u0644\u062a\u062c\u0645\u064a\u0644\u064a",
  "body": "\u0642\u0634\u0648\u0631 \u0627\u0644\u0623\u0633\u0646\u0627\u0646 \u0647\u064a \u0639\u0644\u0627\u0645\u0629 \u062a\u062c\u0627\u0631\u064a\u0629 \u062d\u0627\u0635\u0644\u0629 \u0639\u0644\u0649 \u0628\u0631\u0627\u0621\u0629 \u0627\u062e\u062a\u0631\u0627\u0639 \u0644\u0642\u0634\u0648\u0631 \u0628\u0648\u0631\u0633\u0644\u0627\u0646 \u0631\u0642\u064a\u0642\u0629 \u062c\u062f\u0627\u064b \u2014 \u0628\u0633\u0645\u0643 \u062a\u0642\u0631\u064a\u0628\u064a 0.2 \u0645\u0645\u060c \u0628\u062d\u062c\u0645 \u0627\u0644\u0639\u062f\u0633\u0629 \u0627\u0644\u0644\u0627\u0635\u0642\u0629 \u2014 \u062a\u064f\u0644\u0635\u0642 \u0645\u0628\u0627\u0634\u0631\u0629 \u0639\u0644\u0649 \u0623\u0633\u0646\u0627\u0646\u0643 \u0627\u0644\u0637\u0628\u064a\u0639\u064a\u0629. \u0645\u0635\u0646\u0648\u0639\u0629 \u0645\u0646 \u0628\u0648\u0631\u0633\u0644\u0627\u0646 \u0645\u062a\u062e\u0635\u0635\u060c \u0644\u0627 \u062a\u062a\u0637\u0644\u0628 \u0625\u0632\u0627\u0644\u0629 \u0627\u0644\u0645\u064a\u0646\u0627 \u0623\u0648 \u0628\u0634\u0643\u0644 \u0636\u0626\u064a\u0644\u060c \u0645\u0645\u0627 \u064a\u062c\u0639\u0644\u0647\u0627 \u0625\u062c\u0631\u0627\u0621\u064b \u0637\u0641\u064a\u0641\u064b\u0627 \u0648\u0642\u0627\u0628\u0644\u0627\u064b \u0644\u0644\u0639\u0643\u0633 \u0641\u064a \u0643\u062b\u064a\u0631 \u0645\u0646 \u0627\u0644\u0623\u062d\u064a\u0627\u0646.",
