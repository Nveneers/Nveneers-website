{
  "eyebrow": "\u0627\u0644\u0639\u0646\u0627\u064a\u0629 \u0637\u0648\u064a\u0644\u0629 \u0627\u0644\u0623\u0645\u062f",
  "headline": "\u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0648\u0627\u0644\u0635\u064a\u0627\u0646\u0629",
  "lead": "\u0627\u0644\u0639\u0646\u0627\u064a\u0629 \u0628\u0642\u0634\u0648\u0631 \u0627\u0644\u0623\u0633\u0646\u0627\u0646 \u0628\u0633\u064a\u0637\u0629. \u0645\u0639 \u0627\u0644\u0639\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u062d\u064a\u062d\u0629\u060c \u064a\u0645\u0643\u0646 \u0623\u0646 \u064a\u0633\u062a\u0645\u0631 \u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0643 \u062d\u062a\u0649 \u0639\u0642\u062f\u064a\u0646.",
  "tips": [
    {
      "icon": "brush",
      "title": "\u062a\u0646\u0638\u064a\u0641 \u0627\u0644\u0623\u0633\u0646\u0627\u0646 \u0645\u0631\u062a\u064a\u0646 \u064a\u0648\u0645\u064a\u0627\u064b",
      "description": "\u0627\u0633\u062a\u062e\u062f\u0645 \u0641\u0631\u0634\u0627\u0629 \u0623\u0633\u0646\u0627\u0646 \u0646\u0627\u0639\u0645\u0629 \u0648\u0645\u0639\u062c\u0648\u0646 \u0623\u0633\u0646\u0627\u0646 \u063a\u064a\u0631 \u0643\u0627\u0634\u0637 \u0644\u062d\u0645\u0627\u064a\u0629 \u0633\u0637\u062d \u0627\u0644\u0628\u0648\u0631\u0633\u0644\u0627\u0646."
    },
    {
      "icon": "guard",
      "title": "\u0627\u0631\u062a\u062f\u0627\u0621 \u0648\u0627\u0642\u064a \u0644\u064a\u0644\u064a",
      "description": "\u0625\u0630\u0627 \u0643\u0646\u062a \u062a\u0637\u062d\u0646 \u0623\u0633\u0646\u0627\u0646\u0643 \u0644\u064a\u0644\u0627\u064b\u060c \u0641\u0625\u0646 \u0627\u0644\u0648\u0627\u0642\u064a \u0627\u0644\u0645\u062e\u0635\u0635 \u064a\u062d\u0645\u064a \u0642\u0634\u0648\u0631\u0643 \u0645\u0646 \u0627\u0644\u0636\u063a\u0637 \u0627\u0644\u0645\u0641\u0631\u0637."
    },
    {
      "icon": "calendar",
      "title": "\u0641\u062d\u0648\u0635\u0627\u062a \u062f\u0648\u0631\u064a\u0629",
      "description": "\u0642\u0645 \u0628\u0632\u064a\u0627\u0631\u0629 \u0637\u0628\u064a\u0628 \u0627\u0644\u0623\u0633\u0646\u0627\u0646 \u0643\u0644 \u0633\u062a\u0629 \u0623\u0634\u0647\u0631 \u0644\u0644\u062a\u0646\u0638\u064a\u0641 \u0627\u0644\u0627\u062d\u062a\u0631\u0627\u0641\u064a \u0648\u0645\u0631\u0627\u0642\u0628\u0629 \u062d\u0627\u0644\u0629 \u0627\u0644\u0642\u0634\u0648\u0631."
    },
    {
      "icon": "food",
      "title": "\u062a\u062c\u0646\u0628 \u0627\u0644\u0623\u0637\u0639\u0645\u0629 \u0627\u0644\u0635\u0644\u0628\u0629",
      "description": "\u0644\u0627 \u062a\u0639\u0636 \u0645\u0628\u0627\u0634\u0631\u0629 \u0639\u0644\u0649 \u0627\u0644\u0623\u0634\u064a\u0627\u0621 \u0627\u0644\u0635\u0644\u0628\u0629 \u0645\u062b\u0644 \u0627\u0644\u062b\u0644\u062c \u0623\u0648 \u0627\u0644\u062d\u0644\u0648\u0649 \u0627\u0644\u0635\u0644\u0628\u0629 \u0628\u0623\u0633\u0646\u0627\u0646\u0643 \u0627\u0644\u0645\u063a\u0637\u0627\u0629."
